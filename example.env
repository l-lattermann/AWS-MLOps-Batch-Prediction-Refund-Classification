# AWS
AWS_REGION=eu-central-1

# Infrastructure
INFRASTRUCTURE_OUTPUT_PATH=terraform/infrastructure.json

# API
API_SERVICE_NAME=<ecs-api-service-name>
API_URL=http://<alb-dns-name>

# ECS
ECS_CLUSTER_NAME=<ecs-cluster-name>
TRAIN_TASK_DEFINITION=<train-task-definition-arn>
BATCH_TASK_DEFINITION=<batch-task-definition-arn>
ECS_SUBNET_IDS=<subnet-id-1>,<subnet-id-2>,<subnet-id-3>
ECS_SECURITY_GROUP_IDS=<security-group-id>

# CloudWatch
CLOUDWATCH_LOG_GROUP=/ecs/<project-name>

# S3
S3_BUCKET=<bucket-name>
DATASETS_PREFIX=datasets/
MODELS_PREFIX=models/
CONFIGS_PREFIX=configs/
INCOMING_IMAGES_PREFIX=incoming-images/

# Configuration files
TRAIN_CONFIG_S3_KEY=config/train/training_params_mobilenetV3L.yml
BATCH_PREDICTION_CONFIG_S3_KEY=config/pred/batch_prediction.yml

# PostgreSQL
POSTGRES_HOST=<rds-endpoint>
POSTGRES_PORT=5432
POSTGRES_DB_NAME=refunddb
POSTGRES_SECRET_ARN=<secrets-manager-secret-arn>